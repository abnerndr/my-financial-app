{
	"semi": true,
	"singleQuote": true,
	"trailingComma": "all",
	"tabWidth": 2,
	"useTabs": true,
	"printWidth": 120,
	"endOfLine": "lf",
	"arrowParens": "always",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"jsxSingleQuote": false,
	"quoteProps": "as-needed",
	"plugins": ["@trivago/prettier-plugin-sort-imports"],
	"importOrder": [
		"^react",
		"^next",
		"^@/components/(.*)$",
		"^@/hooks/(.*)$",
		"^@/lib/(.*)$",
		"^@/types/(.*)$",
		"^[./]"
	],
	"importOrderSeparation": false,
	"importOrderSortSpecifiers": true
}
